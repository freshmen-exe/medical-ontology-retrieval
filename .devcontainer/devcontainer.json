{
  "name": "Medical Ontology Retrieval",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "dev",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "ms-python.isort",
        "charliermarsh.ruff",
        "njpwerner.autodocstring",
        "ms-toolsai.jupyter",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.jupyter-renderers",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "docker.docker",
        "mechatroner.rainbow-csv",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-sqlite",
        "grapecity.gc-excelviewer",
        "eamodio.gitlens",
        "mhutchie.git-graph",
        "donjayamanne.githistory",
        "esbenp.prettier-vscode",
        "aaron-bond.better-comments",
        "formulahendry.auto-close-tag",
        "google.geminicodeassist",
        "github.copilot",
        "github.copilot-chat",
        "anthropic.claude",
        "saoudrizwan.claude-dev",
        "agy.agy",
        "opencode.opencode",
        "kilo.kilo"
      ]
    }
  },
  "remoteUser": "vscode",
  "postCreateCommand": "python -m pip install --upgrade pip setuptools wheel && python -m pip install torch==2.6.0 torchvision==0.21.0 torchaudio==2.6.0 transformers==4.51.3 && python -m pip install --no-build-isolation autoawq==0.2.9 && python -m pip install -r requirements.txt && python -m pip check && pre-commit install && pre-commit install --hook-type pre-push",
  "postAttachCommand": "git config --global --unset-all safe.directory >/dev/null 2>&1 || true; git config --global --add safe.directory /workspace"
}
