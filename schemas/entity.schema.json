{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/entity.schema.json",
  "title": "Medical Entity",
  "type": "object",
  "additionalProperties": false,
  "required": ["text", "position", "type"],
  "properties": {
    "text": {"type": "string", "minLength": 1},
    "position": {
      "type": "array",
      "prefixItems": [
        {"type": "integer", "minimum": 0},
        {"type": "integer", "minimum": 1}
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "type": {
      "enum": [
        "TRIỆU_CHỨNG",
        "TÊN_XÉT_NGHIỆM",
        "KẾT_QUẢ_XÉT_NGHIỆM",
        "CHẨN_ĐOÁN",
        "THUỐC"
      ]
    },
    "assertions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["isNegated", "isFamily", "isHistorical"],
      "properties": {
        "isNegated": {"type": "boolean"},
        "isFamily": {"type": "boolean"},
        "isHistorical": {"type": "boolean"}
      }
    },
    "candidates": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {"properties": {"type": {"enum": ["TRIỆU_CHỨNG", "CHẨN_ĐOÁN", "THUỐC"]}}},
      "then": {"required": ["assertions"]},
      "else": {"not": {"required": ["assertions"]}}
    },
    {
      "if": {"properties": {"type": {"enum": ["CHẨN_ĐOÁN", "THUỐC"]}}},
      "then": {"required": ["candidates"]},
      "else": {"not": {"required": ["candidates"]}}
    }
  ]
}
